# ─────────────────────────────────────────────
#  ROAMERS COMMUNITY — Environment Variables
# ─────────────────────────────────────────────
# Copy this file to .env and fill in the values

# Server
PORT=3000
NODE_ENV=development

# Security — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_this_to_a_long_random_secret_64chars_minimum
JWT_EXPIRES_IN=7d

# Admin credentials (used for first-boot seed)
ADMIN_EMAIL=admin@roamerscommunity.ma
ADMIN_PASSWORD=admin123
ADMIN_NAME=Youssef El Fassi

# Company WhatsApp (international format, no +)
WHATSAPP_NUMBER=212600000000

# Email (SMTP) — leave empty to skip email sending
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=hello@roamerscommunity.ma
SMTP_PASS=your_app_password_here
SMTP_FROM="Roamers Community <hello@roamerscommunity.ma>"

# Database path (relative to project root)
DB_PATH=./data/roamers.db

# Frontend URL (for CORS in production)
FRONTEND_URL=http://localhost:3000
